# Copy to server\.env on the kiosk PC, then edit ADMIN_TOKEN.

DATA_DIR=C:\ProgramData\VRSIWallBoard\data
BACKUP_DIR=C:\ProgramData\VRSIWallBoard\backups

PORT=3001
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3001

# Standalone kiosk (no Microsoft calendar until you configure Azure below)
DISABLE_AZURE=true

# Required — use a long random string (32+ chars); used by server only
ADMIN_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# In-app Support tab (Monitoring → Support) — mailto for customer support reports
SUPPORT_EMAIL=briank@vrs-inc.com

# Set to false before any LAN exposure or reverse proxy placement
TRUST_LOCALHOST=true

# When DISABLE_AZURE is false, also set:
# ENCRYPTION_SECRET=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
