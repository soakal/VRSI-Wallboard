# Dev: use project data folder (JSON migrates to wallboard.db on first run)
DATA_DIR=./server/data
BACKUP_DIR=./server/backups

PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Test mode — mock calendar/SharePoint; board uses SQLite
DISABLE_AZURE=true

# Board API protection (used by non-localhost clients, e.g. curl scripts)
ADMIN_TOKEN=change-me-in-production

# In-app Support tab (Monitoring panel) — mailto destination for support reports
SUPPORT_EMAIL=briank@vrs-inc.com

# Restore conflict heuristic: jobs with backup+live timestamps within this window (ms) are flagged
# as conflicts requiring user resolution. Default 60000 (60 seconds). Set to 0 to disable.
# RESTORE_CONFLICT_WINDOW_MS=60000

# Site-specific person-alias groups for identity deduplication across spreadsheet imports.
# Format: JSON array of alias groups; each group canonicalizes to the first email-like entry.
# Example: PERSON_ALIASES=[["phil g","philg@vrsinc","philg@vrs-inc.com"],["ted h","tedh","tedh@vrs-inc.com"]]
# PERSON_ALIASES=

# Required when DISABLE_AZURE is not set:
# ENCRYPTION_SECRET=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# CORS_ORIGIN=http://localhost:3001
